# Backend environment for Docker
# Docker service hostnames replace localhost

NODE_ENV=development
PORT=5000

# ── Database (via PGBouncer connection pooler) ───────────
DB_HOST=pgbouncer
DB_PORT=5433
DB_NAME=edunexus
DB_USER=edunexus_user
DB_PASSWORD=edunexus_pass

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT Secrets ──────────────────────────────────────────
JWT_ACCESS_SECRET=7f5e8b2a1c4d9e3f6a0b8c9d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f
JWT_REFRESH_SECRET=a1b2c3d4e5f60718293a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# ── Security ─────────────────────────────────────────────
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION=900000

# ── CORS ─────────────────────────────────────────────────
# Frontend is on port 80 in Docker (Vite on :5173 proxied to :80)
CORS_ORIGIN=http://localhost

# ── SaaS ─────────────────────────────────────────────────
SAAS_MODE=true
APP_URL=http://localhost

# ── Stripe (placeholders for local dev) ──────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_LOGIN_MAX=5
