# Environment
NODE_ENV=test

# Server
PORT=5001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edunexus_test
DB_USER=postgres
DB_PASSWORD=Pr@dumn121

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Secrets
JWT_ACCESS_SECRET=test_access_secret_very_long_and_secure_for_testing
JWT_REFRESH_SECRET=test_refresh_secret_very_long_and_secure_for_testing

