# Production Environment Configuration
PORT=5000
NODE_ENV=production

# Database (Secrets should be injected via Docker Secrets or Environment)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=edunexus
DB_USER=edunexus_admin
DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Security
JWT_SECRET=REPLACE_WITH_SECURE_LONG_STRING
REFRESH_TOKEN_SECRET=REPLACE_WITH_SECURE_LONG_STRING
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Rate Limiting
WINDOW_MS=900000
MAX_REQUESTS=100
LOGIN_MAX=5

# CORS
CORS_ORIGIN=https://edunexus.yourdomain.com
