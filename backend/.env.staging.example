# Staging Environment Configuration
PORT=5000
NODE_ENV=staging

DB_HOST=postgres
DB_PORT=5432
DB_NAME=edunexus_staging
DB_USER=edunexus_admin
DB_PASSWORD=staging_password

REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET=staging_secret
REFRESH_TOKEN_SECRET=staging_refresh_secret
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

WINDOW_MS=900000
MAX_REQUESTS=1000
LOGIN_MAX=20

CORS_ORIGIN=https://staging.edunexus.yourdomain.com
